# Copy this file to .env and fill in the keys you want to use.
# Keep .env private. It is ignored by git.

# Choose one: heuristic, auto, openai, anthropic
VISION_PROVIDER=heuristic

# Optional OpenAI vision model support
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Anthropic Claude vision model support
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional direct platform publishing (OAuth — keep secrets in .env only)
# YouTube: create a Google Cloud OAuth "Desktop" client
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok: requires approved TikTok developer app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Meta/Instagram: requires Meta developer app + Business/Creator account
META_APP_ID=
META_APP_SECRET=
